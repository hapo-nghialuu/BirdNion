  "scope_lock": {
    "source": "Add an opt-in feature that automatically primes the Codex 5-hour rate-limit window by sending one small `codex exec` request on a schedule, so the window reset cycle aligns with the user's working hours.",
    "in_scope": [
      "SettingsStore keys: codexAutoPrimeEnabled (Bool=false), codexAutoPrimeMinutes (Int=535), codexAutoPrimeLastRun (Double=0)",
      "Settings UI toggle + hour/minute time control in the Codex provider detail (ProvidersPane)",
      "CodexQuotaPrimer type hosted in existing CodexAccountStore.swift: pure shouldPrime(...), prime() async, tick()",
      "Wire tick() into QuotaService.refresh(...) codex path (reuse existing cadence, no new Timer)",
      "Optional local notification 'primed HH:mm' via existing QuotaNotifier/UserNotifications",
      "vi + en L10n strings",
      "Unit tests for pure shouldPrime(...) in BirdNionTests/CodexProviderTests.swift"
    ],
    "out_of_scope": [
      "Redeem/POST of Codex reset-credit",
      "Priming multiple accounts simultaneously",
      "Waking a sleeping machine",
      "Changes to the codex-account-switcher feature",
      "New third-party dependencies or new .swift files where an existing file can host the type",
      "Changing ProviderStatus / QuotaProvider signatures"
    ],
    "expansion_policy": "requires-user-approval"
  },
