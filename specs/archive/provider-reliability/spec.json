  "scope_lock": {
    "source": "macOS-first reliability core (roadmap Phase 7 items 1-3): per-provider self-test button, actionable error classification with remediation hints, failure-transition notification after >=3 consecutive failing cycles.",
    "in_scope": [
      "Pure Swift error classification: ProviderErrorKind enum + classify(rawError:) function over existing error strings/HTTP codes, unit-testable",
      "Per-group short remediation hint (en+vi) shown instead of raw error string",
      "Per-provider self-test button in Settings -> Providers detail pane: single fetch via existing provider fetch path, inline pass/fail + classified reason",
      "Classified message shown in sidebar row subtitle AND detail info grid; raw error kept available via tooltip/help",
      "Failure-transition notification via existing QuotaNotifier when a provider goes OK -> failing for >=3 consecutive refresh cycles; fire once per failure episode; reset on recovery",
      "New localization strings in AppLocalizer (en+vi tables)"
    ],
    "out_of_scope": [
      "Linux/Tauri sync (separate roadmap item)",
      "Windows port",
      "Redesign of the existing quota-warning threshold system (QuotaWarnConfig)",
      "New network layer or new provider fetch path",
      "New third-party dependencies",
      "CI GitHub Actions setup (Phase 7 item 4)",
      "Semi-auto brew update button (Phase 7 item 5)",
      "Retry/backoff logic or auto-recovery beyond notification",
      "Changing ProviderStatus error invariant or provider fetch signatures"
    ],
    "expansion_policy": "requires-user-approval"
  },
